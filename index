7.8, 14800, 15200, "both", "高中", 55, ["新北大型校", "升學穩定"], ["特色課程"]], ["丹鳳", 18.8, 15000, 15400, "both", "高中", 62, ["新莊生活圈", "校風穩定"], ["特色課程"]], ["永春", 18.6, 15300, 15700, "both", "高中", 35, ["信義生活圈", "交通便利"], ["特色課程"]], ["新店", 17.8, 17000, 17450, "both", "高中", 18, ["通勤優勢", "新店生活圈"], ["特色課程"]], ["萬芳", 17.6, 17350, 17800, "both", "高中", 18, ["文山近距離", "通勤優勢"], ["特色課程"]], ["錦和", 16.6, 19200, 19600, "both", "高中", 35, ["中和生活圈", "校風穩定"], ["特色課程"]], ["大安高工", 19.8, 13800, 14200, "both", "高職", 25, ["技職強校", "理工實作"], ["技術型高中"]], ["木柵高工", 8.6, 32300, 32700, "both", "高職", 20, ["文山近距離", "技職導向"], ["技術型高中"]]].map(x=>({name:x[0],score:x[1],low:x[2],high:x[3],gender:x[4],type:x[5],commute:x[6],features:x[7],special:x[8]}));
function fmt(n){return Math.round(n).toLocaleString('zh-TW')}function mid(a,b){return Math.round((a+b)/2)}function rt(a,b){return `${fmt(a)}～${fmt(b)}`}function stars(n){return n>=15?'★★★★★':n>=10?'★★★★☆':n>=5?'★★★☆☆':n>=2?'★★☆☆☆':'★☆☆☆☆'}
function scoreToRange(score){if(score===null||isNaN(score))return null;let exact=SCORE_RANGES.find(x=>Number(x.score)===Number(score));if(exact)return {...exact,source:'真實樣本區間'};let arr=SCORE_RANGES.slice().sort((a,b)=>b.score-a.score);if(score>=arr[0].score)return {...arr[0],source:'外推'};if(score<=arr[arr.length-1].score)return {...arr[arr.length-1],source:'外推'};for(let i=0;i<arr.length-1;i++){let hi=arr[i],lo=arr[i+1];if(score<=hi.score&&score>=lo.score){let t=(hi.score-score)/(hi.score-lo.score);return {score,low:Math.round(hi.low+t*(lo.low-hi.low)),high:Math.round(hi.high+t*(lo.high-hi.high)),samples:0,source:'區間插值'}}}return null}
function getStudentRange(){let lo=parseInt(rankLow.value),hi=parseInt(rankHigh.value),sc=parseFloat(score.value);if(!isNaN(lo)&&!isNaN(hi))return {low:Math.min(lo,hi),high:Math.max(lo,hi),source:'輸入序位區間',samples:null};if(!isNaN(lo))return {low:lo,high:lo,source:'輸入單一序位',samples:null};return scoreToRange(sc)}
function filtered(){let g=gender.value,t=type.value;return schools.filter(s=>(g==='all'||s.gender==='both'||s.gender===g)&&(t==='all'||s.type===t)).sort((a,b)=>a.low-b.low)}
function judge(stu,sch){let sm=mid(stu.low,stu.high),cm=mid(sch.low,sch.high),gap=cm-sm,over=!(stu.high<sch.low||stu.low>sch.high);if(over||Math.abs(gap)<=800)return {label:'穩',cls:'amber',badge:'b-stable',gap};if(gap<-1500)return {label:'大衝',cls:'super',badge:'b-super',gap};if(gap<-800)return {label:'衝',cls:'red',badge:'b-rush',gap};if(gap>2000)return {label:'超保',cls:'blue',badge:'b-very',gap};if(gap>800)return {label:'保',cls:'green',badge:'b-safe',gap};return {label:'穩',cls:'amber',badge:'b-stable',gap}}
