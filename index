function pill(s,stu){let j=judge(stu,s);return `<span class="pill">${s.name}<small> ${rt(s.low,s.high)}｜${j.gap>=0?'+':''}${fmt(j.gap)}｜<span class="time">${s.commute}分</span>｜${j.label}</small></span>`}
function zone(title,cls,arr,stu){return `<div class="zone ${cls}"><h3>${title}</h3><div class="pills">${arr.length?arr.slice(0,16).map(s=>pill(s,stu)).join(''):'無'}</div></div>`}
function run(){let stu=getStudentRange();if(!stu){alert('請輸入個人序位區間，或輸入會考積分');return}let sm=mid(stu.low,stu.high),pl=(stu.low/TOTAL*100).toFixed(2),ph=(stu.high/TOTAL*100).toFixed(2);let L=filtered().map(s=>({...s,j:judge(stu,s)}));let cur=L.find(s=>s.high>=stu.low)||L[L.length-1];let g={super:[],red:[],amber:[],green:[],blue:[]};L.forEach(s=>g[s.j.cls].push(s));summary.innerHTML=`<div class="metrics"><div class="metric"><div class="k">採用序位區間</div><div class="v">${rt(stu.low,stu.high)}</div><div class="small">${stu.source}</div></div><div class="metric"><div class="k">百分位區間</div><div class="v">前 ${pl}%～${ph}%</div><div class="small">母體 ${fmt(TOTAL)}</div></div><div class="metric"><div class="k">樣本可信度</div><div class="v"><span class="stars">${stu.samples==null?'-':stars(stu.samples)}</span></div><div class="small">${stu.samples==null?'直接輸入序位':'樣本數 '+stu.samples}</div></div><div class="metric"><div class="k">理論落點帶</div><div class="v">${cur.name}</div><div class="small">${rt(cur.low,cur.high)}</div></div></div>`;zones.innerHTML=zone('⬛ 大衝區','super',g.super,stu)+zone('🟥 衝刺區','red',g.red,stu)+zone('🟨 穩定區／區間重疊','amber',g.amber,stu)+zone('🟩 保守區','green',g.green,stu)+zone('🟦 超保區','blue',g.blue,stu);renderCompare(stu);renderPlan(stu);result.classList.remove('hidden');compare.classList.remove('hidden');planCard.classList.remove('hidden')}
function renderCompare(stu){let L=filtered().map(s=>({...s,j:judge(stu,s)})),idx=L.findIndex(s=>s.high>=stu.low);if(idx<0)idx=L.length-1;let rows=L.slice(Math.max(0,idx-10),idx+14).map(s=>`<tr><td>${s.name}<br>${tagHtml(s)}</td><td>${s.type}</td><td class="num">${s.score??'-'}</td><td class="num">${rt(s.low,s.high)}</td><td class="num">${s.j.gap>=0?'+':''}${fmt(s.j.gap)}</td><td><span class="badge ${s.j.badge}">${s.j.label}</span></td><td class="num"><span class="time">${s.commute}分</span></td></tr>`).join('');table.innerHTML=`<table><tr><th>校科與特色</th><th>類型</th><th>積分</th><th>學校序位區間</th><th>區間差距</th><th>判定</th><th>通勤</th></tr>${rows}</table>`}
function renderPlan(stu){let n=parseInt(topn.value);let L=filtered().map(s=>({...s,j:judge(stu,s)}));let top=L.filter(s=>['大衝','衝','穩'].includes(s.j.label)).sort((a,b)=>a.low-b.low).slice(0,n);let used=new Set(top.map(s=>s.name));let rest=L.filter(s=>!used.has(s.name)).sort((a,b)=>{let o={'穩':1,'保':2,'超保':3,'衝':4,'大衝':5};return (o[a.j.label]||9)-(o[b.j.label]||9)||a.commute-b.commute});let p=top.concat(rest).slice(0,30);plan.innerHTML=p.map((s,i)=>`<div class="planrow"><span class="idx${i<n?'':' local'}">${i+1}</span><span class="nm">${s.name} <span class="badge ${s.j.badge}">${s.j.label}</span><br><small>${s.features.slice(0,2).join('、')}｜${s.special.slice(0,1).join('、')}</small></span><span class="meta">${rt(s.low,s.high)}｜${s.commute}分</span></div>`).join('')||'目前條件沒有足夠學校。'}
function renderDB(){let kw=q.value.trim();let rows=filtered().filter(s=>!kw||s.name.includes(kw)).map((s,i)=>`<tr><td>${i+1}</td><td>${s.name}<br>${tagHtml(s)}</td><td>${s.type}</td><td class="num">${s.score??'-'}</td><td class="num">${rt(s.low,s.high)}</td><td class="num"><span class="time">${s.commute}分</span></td></tr>`).join('');db.innerHTML=`<table><tr><th>#</th><th>校科與特色</th><th>類型</th><th>積分</th><th>序位區間</th><th>通勤</th></tr>${rows}</table>`}
